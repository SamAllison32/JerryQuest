/// @DnDHash : 1CAA552D
/// @DnDArgument : "code" "draw_set_font(gamefont);$(13_10)$(13_10)c = c_white$(13_10)$(13_10)talk[0] = "(This will never be seen in-game!";$(13_10)talk[1] = "Heya kid. Listen carefully. I'm only gonna say this once... (Unless you die and restart the room...)";$(13_10)talk[2] = "In order to get the Crown of BoingaBoom, and therefore gain extra jumping power, you must collect five coins scattered around this test level.";$(13_10)$(13_10)talk[3] = "I would help you get them myself, but the game developer has not given me the liberty of movement.";$(13_10)talk[4] = "So, I'll simply give you some advice.";$(13_10)talk[5] = "You can aquire most of these coins by crouching (Down Arrow), or just by abusing the broken tilemap.";$(13_10)talk[6] = "You can also press ''C'' to reset your position in the room, lest you come across a sticky situation.";$(13_10)talk[7] = "Additionally, you may press ''J'' to skip the game and simply view the completed power-up, in case you don't feel like completing this experience.";$(13_10)talk[8] = "I will watch your efforts in silence from here on out, unless you are misfortunate enough to fall into a pit of spikes. I wish you the best of luck.";$(13_10)$(13_10)lastpage = 9;$(13_10)$(13_10)page = 0;$(13_10)$(13_10)$(13_10)$(13_10)speaky = false;$(13_10)clickoff = false;$(13_10)extra = false;"
draw_set_font(gamefont);

c = c_white

talk[0] = "(This will never be seen in-game!";
talk[1] = "Heya kid. Listen carefully. I'm only gonna say this once... (Unless you die and restart the room...)";
talk[2] = "In order to get the Crown of BoingaBoom, and therefore gain extra jumping power, you must collect five coins scattered around this test level.";

talk[3] = "I would help you get them myself, but the game developer has not given me the liberty of movement.";
talk[4] = "So, I'll simply give you some advice.";
talk[5] = "You can aquire most of these coins by crouching (Down Arrow), or just by abusing the broken tilemap.";
talk[6] = "You can also press ''C'' to reset your position in the room, lest you come across a sticky situation.";
talk[7] = "Additionally, you may press ''J'' to skip the game and simply view the completed power-up, in case you don't feel like completing this experience.";
talk[8] = "I will watch your efforts in silence from here on out, unless you are misfortunate enough to fall into a pit of spikes. I wish you the best of luck.";

lastpage = 9;

page = 0;



speaky = false;
clickoff = false;
extra = false;